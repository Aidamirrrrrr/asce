{
  "name": "asce",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n web,worker -c blue,magenta \"pnpm dev:web\" \"pnpm dev:worker\"",
    "dev:web": "next dev",
    "dev:worker": "BOT_WORKER_PROCESS=1 tsx scripts/bot-worker.ts",
    "build": "next build",
    "start": "next start",
    "start:worker": "BOT_WORKER_PROCESS=1 tsx scripts/bot-worker.ts",
    "lint": "biome check --error-on-warnings",
    "lint:fix": "biome check --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev && prisma generate",
    "db:migrate:deploy": "prisma migrate deploy && prisma generate",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1069.0",
    "@aws-sdk/s3-request-presigner": "^3.1069.0",
    "@base-ui/react": "^1.5.0",
    "@dagrejs/dagre": "^3.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@xyflow/react": "^12.11.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "embla-carousel-react": "^8.6.0",
    "grammy": "^1.44.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.18.0",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.1",
    "openai": "^6.42.0",
    "pg": "^8.21.0",
    "radix-ui": "^1.5.0",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.0",
    "redis": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
