generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  subscription  Subscription?
  aiUsage       AiUsage[]
  platformPayments PlatformPayment[]
}

/// Платная подписка платформы (тариф на использование конструктора и ИИ).
model Subscription {
  id                      String    @id @default(cuid())
  userId                  String    @unique
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                  String    @default("free")
  status                  String    @default("active") // active | past_due | canceled
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean   @default(false)
  yookassaPaymentMethodId String? // сохранённый способ оплаты для автоплатежей
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

/// Помесячный агрегат расхода ИИ-токенов по пользователю (для квот и наблюдаемости).
model AiUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period    String // "2026-06"
  tokens    Int      @default(0)
  calls     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, period])
  @@index([userId])
}

/// Платёж платформы через ЮKassa (оплата подписки), с идемпотентностью по paymentId.
model PlatformPayment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String   @default("yookassa")
  paymentId String
  planId    String
  amount    String
  currency  String   @default("RUB")
  status    String   @default("pending") // pending | succeeded | canceled
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, paymentId])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  prompt        String?
  status        String         @default("draft")
  flowJson      String?
  chatJson      String?
  botToken      String?
  webhookSecret String?
  deliveryMode  String         @default("webhook")
  runtimeStatus String         @default("stopped")
  lastError     String?
  lastStartedAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  assets        ProjectAsset[]
  scheduledJobs ScheduledFlowJob[]
  knownChats    ProjectKnownChat[]
  secrets       ProjectSecret[]
  userVariables ProjectUserVariable[]
  botUsers      BotUser[]
  botEvents     BotEvent[]
  records       ProjectRecord[]

  @@index([userId])
}

/// Пользователь конкретного бота (1:1 чат). Аналитика «сколько пользователей».
model BotUser {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  chatId      String
  username    String?
  firstName   String?
  lastName    String?
  languageCode String?
  isPremium   Boolean  @default(false)
  isBot       Boolean  @default(false)
  blocked     Boolean  @default(false)
  messageCount Int     @default(0)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@unique([projectId, userId])
  @@index([projectId, lastSeenAt])
  @@index([projectId, firstSeenAt])
}

/// Журнал событий бота (append-only). Источник для аналитики/воронок.
model BotEvent {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String?
  chatId    String?
  type      String
  nodeId    String?
  meta      String?
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([projectId, type, createdAt])
}

model ProjectKnownChat {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chatId      String
  title       String
  username    String?
  chatType    String
  botIsAdmin  Boolean  @default(false)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, chatId])
  @@index([projectId, lastSeenAt])
}

model ScheduledFlowJob {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chatId      String
  nodeId      String
  contextJson String
  runAt       DateTime
  status      String   @default("pending")
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, runAt])
  @@index([projectId])
}

model ProjectSecret {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key         String
  value       String   @default("")
  label       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, key])
  @@index([projectId])
}

model ProjectUserVariable {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId, key])
  @@index([projectId, userId])
}

/// Собранные ботом данные (заявки, лиды, записи). Пишет узел save_record.
model ProjectRecord {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  collection String
  dataJson   String
  userId     String?
  chatId     String?
  createdAt  DateTime @default(now())

  @@index([projectId, collection, createdAt])
}

model ProcessedPayment {
  id        String   @id @default(cuid())
  projectId String
  provider  String   @default("yookassa")
  paymentId String
  createdAt DateTime @default(now())

  @@unique([projectId, provider, paymentId])
  @@index([projectId])
}

model ProjectAsset {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kind            String
  fileName        String
  mimeType        String
  sizeBytes       Int
  storageKey      String
  telegramFileId  String?
  createdAt       DateTime @default(now())

  @@index([projectId])
}
