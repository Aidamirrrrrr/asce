DATABASE_URL="postgresql://postgres:postgres@localhost:5432/telegram_bot_builder?schema=public"
APP_URL="http://localhost:3000"
# Бета на Immers.cloud Qwen3-Coder-Next (OpenAI-совместимый). BASE_URL без /chat/completions — SDK добавит сам.
AI_API_KEY=""
AI_BASE_URL="https://chat.immers.cloud/v1/endpoints/qwen3-coder-next-tensor/generate"
AI_MODEL="Qwen3-Coder-Next"

# Media storage (local in dev, S3 in production)
MEDIA_STORAGE_DRIVER="local"
MEDIA_STORAGE_PATH="./uploads"
# S3 / MinIO (prod). MinIO: задайте S3_ENDPOINT и ключи; бакет создайте заранее.
# S3_BUCKET="asce-media"
# S3_REGION="us-east-1"
# S3_ENDPOINT=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""

# Bearer-токен для /api/cron/process-jobs (обязателен в production)
# CRON_SECRET=""

# Redis (сессии бота и rate limiting; в dev без REDIS_URL — in-memory fallback)
REDIS_URL="redis://localhost:6379"

# Auth.js
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Dev-обход авторизации: кнопка входа без пароля/кода. Работает ТОЛЬКО вне production.
# DEV_AUTH_SKIP="true"

# Шифрование секретов и botToken at-rest (обязательно в production)
# SECRETS_ENC_KEY=""

# Биллинг платформы: ЮKassa магазина платформы (НЕ секреты ботов) для оплаты подписки
# YOOKASSA_SHOP_ID=""
# YOOKASSA_SECRET_KEY=""
# Секрет для проверки подписи уведомлений ЮKassa (опционально; статус всё равно перепроверяется через API)
# YOOKASSA_NOTIFICATION_SECRET=""
# Себестоимость ИИ за 1M токенов в рублях — для расчёта маржи тарифов (по умолчанию 400)
# AI_COST_PER_1M_RUB="400"

# Бета: одновременных ИИ-запросов к модели (очередь защищает общий эндпоинт).
# Нагрузочный тест Qwen/Immers: безопасно до ~40-60, деградация на 80, отказ на 120.
AI_MAX_CONCURRENCY="24"
# Бета: максимум зарегистрированных пользователей (0 = без лимита)
MAX_BETA_USERS="100"

# SMTP (почтовый сервер reg.ru) — для кода-второго-фактора при входе.
# Порт 465 = SSL, 587 = STARTTLS. Без этих переменных вход по коду отключается.
SMTP_HOST="mail.hosting.reg.ru"
SMTP_PORT="465"
SMTP_USER="hello@asce.tech"
SMTP_PASS=""
SMTP_FROM="asce <hello@asce.tech>"
# Куда слать обратную связь из приложения (по умолчанию hello@asce.tech)
# FEEDBACK_TO="hello@asce.tech"
